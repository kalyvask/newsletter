{
  "version": 2,
  "builds": [
    {
      "src": "api/newsletter.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/newsletter(.*)",
      "dest": "/api/newsletter.py"
    }
  ],
  "crons": [
    {
      "path": "/api/newsletter?type=daily",
      "schedule": "0 9 * * *"
    }
  ]
}
